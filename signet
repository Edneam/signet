#!/usr/bin/env bash
# signet — local, private voice dictation + AI commands for Hyprland.
# Speak, get clean text anywhere. whisper.cpp + Gemma, fully on-device.
set -uo pipefail

VERSION="0.6.0"
APP="signet"

# ---------- XDG paths ----------
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/$APP"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/$APP"
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/$APP"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/$APP"
CONFIG="$CONFIG_DIR/config"
DICT="$CONFIG_DIR/dictionary.txt"
SNIPPETS="$CONFIG_DIR/snippets"
LOG="$STATE_DIR/signet.log"
WAV="$RUNTIME_DIR/rec.wav"
CLEANWAV="$RUNTIME_DIR/rec_clean.wav"
PIDFILE="$RUNTIME_DIR/rec.pid"
MODEFILE="$RUNTIME_DIR/mode"
CLIPBAK="$RUNTIME_DIR/clip.bak"
HIST="$STATE_DIR/history"
LAST="$RUNTIME_DIR/last_insert"      # {epoch}\n{text} of the last inserted dictation (for undo)
UNDO_WINDOW=15                       # seconds after a dictation that Super+Backspace will undo it
mkdir -p "$CONFIG_DIR" "$STATE_DIR" "$DATA_DIR/models" "$RUNTIME_DIR" 2>/dev/null

# ---------- defaults (override in $CONFIG) ----------
MODEL=""                       # auto-detected if empty
WHISPER=""                     # auto-detected if empty
GEMMA="gemma4:e2b"
OLLAMA="http://localhost:11434"
KEEP_ALIVE="30m"
LANG_CODE="en"
PASTE_MODE="auto"              # auto | paste | clipboard | stdout
SOUND=1
MIC="@DEFAULT_AUDIO_SOURCE@"
ON_OLLAMA_DOWN="warn-raw"      # warn-raw | abort
CLEANUP=1                      # 1 = Gemma polish ; 0 = fast (whisper only)
THREADS=8
WTYPE_DELAY=12                 # ms between keystrokes when typing directly (fixes dropped/doubled chars)
TONE="auto"                    # legacy alias for MODE
MODE="auto"                    # auto | default | email | message | code | notes | formal
STT_ENGINE="parakeet"          # parakeet (fast, warm server) | whisper (whisper.cpp)
ASR_PYTHON="$DATA_DIR/asr/bin/python"      # venv python for the Parakeet server
ASR_MODEL_DIR="$DATA_DIR/models/parakeet-v3"
ASR_PORT=8126
GEMMA_BACKEND="local"          # legacy fallback (used when per-mode backends unset)
DICTATE_BACKEND=""             # F9 cleanup: local | aistudio  (default: local)
AGENT_BACKEND=""               # F10 agent:  local | aistudio  (default: aistudio)
AISTUDIO_KEY=""                # free key from aistudio.google.com/apikey (put in config, NOT in repo)
AISTUDIO_MODEL="gemma-4-26b-a4b-it"  # fast MoE (~4B active); plenty for routing + cleanup
AISTUDIO_URL="https://generativelanguage.googleapis.com/v1beta/openai/chat/completions"
[ -f "$CONFIG" ] && . "$CONFIG"
# per-mode backend defaults (fall back to GEMMA_BACKEND, then sensible defaults)
DICTATE_BACKEND="${DICTATE_BACKEND:-${GEMMA_BACKEND:-local}}"
AGENT_BACKEND="${AGENT_BACKEND:-aistudio}"
# back-compat: honor old TONE setting if MODE wasn't customized
[ "${MODE:-auto}" = auto ] && [ "${TONE:-auto}" != auto ] && MODE="$TONE"
# resolve the Parakeet server script next to this binary (repo or /usr/bin)
ASR_SERVER="$(dirname "$(readlink -f "$0")")/signet-asr"

# auto-detect whisper binary
if [ -z "$WHISPER" ]; then
  WHISPER=$(command -v whisper-cli 2>/dev/null) || true
  [ -z "$WHISPER" ] && WHISPER="$HOME/projects/whisper.cpp/build/bin/whisper-cli"
fi
# auto-detect model (base.en fast default, then small.en)
if [ -z "$MODEL" ]; then
  for m in "$DATA_DIR/models/ggml-base.en.bin" "$HOME/projects/whisper.cpp/models/ggml-base.en.bin" \
           "$DATA_DIR/models/ggml-small.en.bin" "$HOME/projects/whisper.cpp/models/ggml-small.en.bin"; do
    [ -f "$m" ] && { MODEL="$m"; break; }
  done
fi

# ---------- helpers ----------
log(){ echo "$(date '+%F %T') $*" >> "$LOG"; }
notify(){ command -v notify-send >/dev/null && notify-send -u low -t 2000 -a "Signet" "$1" "${2:-}" 2>/dev/null || true; }
have(){ command -v "$1" >/dev/null 2>&1; }
blip(){ [ "$SOUND" = 1 ] || return 0; local f="$DATA_DIR/$1.wav"; [ -f "$f" ] && have pw-play && (pw-play --volume 0.4 "$f" >/dev/null 2>&1 &) || true; }
die(){ notify "⚠️ $1" "${2:-}"; log "ERROR: $1 ${2:-}"; echo "signet: $1" >&2; exit 1; }
ollama_up(){ curl -s --max-time 2 "$OLLAMA/api/tags" >/dev/null 2>&1; }
asr_up(){ curl -s --max-time 1 "http://127.0.0.1:$ASR_PORT/" >/dev/null 2>&1; }
asr_ensure(){ # start the warm Parakeet server if not already running
  asr_up && return 0
  [ -x "$ASR_PYTHON" ] && [ -f "$ASR_SERVER" ] && [ -d "$ASR_MODEL_DIR" ] || return 1
  log "starting parakeet server"
  nohup "$ASR_PYTHON" "$ASR_SERVER" "$ASR_MODEL_DIR" "$ASR_PORT" >>"$STATE_DIR/asr.log" 2>&1 &
  for _ in $(seq 1 60); do asr_up && { log "parakeet up"; return 0; }; sleep 0.5; done
  log "parakeet failed to start"; return 1
}
warm_bg(){ [ "$DICTATE_BACKEND" = local ] || [ "$AGENT_BACKEND" = local ] && ( curl -s --max-time 30 "$OLLAMA/api/generate" -d "$(jq -n --arg m "$GEMMA" --arg k "$KEEP_ALIVE" '{model:$m,prompt:"",stream:false,think:false,keep_alive:$k}')" >/dev/null 2>&1 & ); [ "$STT_ENGINE" = parakeet ] && ( asr_ensure & ); return 0; }
[ -f "$LOG" ] && [ "$(stat -c%s "$LOG" 2>/dev/null||echo 0)" -gt 1048576 ] && mv "$LOG" "$LOG.1"

# $1 = backend (local|aistudio)
llm_ready(){ if [ "$1" = aistudio ]; then [ -n "$AISTUDIO_KEY" ]; else ollama_up; fi; }
# llm_chat_messages <backend> <messages-json> -> content
llm_chat_messages(){
  local backend="$1" msgs="$2"
  if [ "$backend" = aistudio ] && [ -n "$AISTUDIO_KEY" ]; then
    curl -s --max-time 60 "$AISTUDIO_URL" -H "Authorization: Bearer $AISTUDIO_KEY" -H "Content-Type: application/json" \
      -d "$(jq -n --arg m "$AISTUDIO_MODEL" --argjson msgs "$msgs" '{model:$m,temperature:0,messages:$msgs}')" \
      | jq -r '.choices[0].message.content // empty' \
      | perl -0777 -pe 's{<thought>.*?</thought>}{}gs; s{<think>.*?</think>}{}gs' \
      | sed 's/^ *//; s/ *$//'
  else
    curl -s --max-time 60 "$OLLAMA/api/chat" -d "$(jq -n --arg m "$GEMMA" --arg k "$KEEP_ALIVE" --argjson msgs "$msgs" \
      '{model:$m,think:false,stream:false,keep_alive:$k,options:{temperature:0,num_predict:400,stop:["\nInput:","Input:"]},messages:$msgs}')" \
      | jq -r '.message.content // empty' | sed 's/^ *//; s/ *$//'
  fi
}
gemma_chat(){ # $1 backend $2 system $3 user -> content
  llm_chat_messages "$1" "$(jq -n --arg s "$2" --arg u "$3" '[{role:"system",content:$s},{role:"user",content:$u}]')"
}

mode_hint(){ # per-context guidance appended to the cleanup prompt; auto from active window
  local m="$MODE" cls
  if [ "$m" = auto ]; then
    cls=$(hyprctl activewindow -j 2>/dev/null | jq -r '.class // empty' | tr '[:upper:]' '[:lower:]')
    case "$cls" in
      *mail*|*thunderbird*|*gmail*) m=email ;;
      *slack*|*discord*|*telegram*|*whats*|*signal*) m=message ;;
      *code*|*term*|*kitty*|*foot*|*ghostty*|*alacritty*|*wezterm*|*nvim*|*vim*) m=code ;;
      *obsidian*|*notes*|*logseq*|*zettlr*) m=notes ;;
      *) m=default ;;
    esac
  fi
  case "$m" in
    email)   echo " Context: an email — clear, professional tone; keep greetings/sign-offs." ;;
    message) echo " Context: a chat message — natural, casual tone." ;;
    code)    echo " Context: a terminal/code editor — terse and literal; do NOT use bullet points; keep commands/code verbatim." ;;
    notes)   echo " Context: notes — use bullet points and structure freely where it helps." ;;
    formal)  echo " Use a formal tone." ;;
    *) echo "" ;;
  esac
}

# ---------- recording ----------
cmd_start(){
  [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null && exit 0
  have pw-record || die "pw-record not found" "install pipewire"
  printf '%s' "${1:-dictate}" > "$MODEFILE"
  log "START (${1:-dictate})"
  case "${1:-dictate}" in
    command)   notify "🛠️  Command…" ;;
    agent)     notify "🤖 Agent…" ;;
    *)         notify "🎤 Recording…" ;;
  esac
  blip start
  warm_bg
  pw-record --target "$MIC" --rate 16000 --channels 1 "$WAV" &
  echo $! > "$PIDFILE"
}

transcribe(){ # $1 = lang ; echoes cleaned RAW transcript
  local src="$WAV" lang="${1:-$LANG_CODE}" names=""
  if have ffmpeg; then
    ffmpeg -y -i "$WAV" -af "highpass=f=100,lowpass=f=8000,silenceremove=start_periods=1:start_duration=0.1:start_threshold=-45dB:detection=peak,areverse,silenceremove=start_periods=1:start_duration=0.1:start_threshold=-45dB:detection=peak,areverse,dynaudnorm=f=200" -ar 16000 -ac 1 "$CLEANWAV" 2>/dev/null && [ -s "$CLEANWAV" ] && src="$CLEANWAV"
  fi
  # Parakeet (warm server) — fast, auto-language, no prompt biasing
  if [ "$STT_ENGINE" = parakeet ] && asr_ensure; then
    curl -s --max-time 60 --data-binary "$src" "http://127.0.0.1:$ASR_PORT/" | tr '\n' ' ' | sed 's/^ *//; s/ *$//'
    return
  fi
  # whisper.cpp fallback
  [ -f "$DICT" ] && names=$(grep -vE '^\s*$|^#' "$DICT" | paste -sd ', ')
  "$WHISPER" -m "$MODEL" -l "$lang" -nt -sns -bo 1 -bs 1 ${names:+--prompt "$names"} -f "$src" -t "$THREADS" 2>/dev/null \
    | tr '\n' ' ' | sed 's/^ *//; s/ *$//'
}

is_junk(){ # $1 raw -> 0 if junk/silence hallucination
  local j; j=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -d '[:punct:][:space:]')
  case "$j" in ""|you|youyou|thankyou|thanks|thanksforwatching|okay|ok|bye|so|uh|um|blankaudio|musicplaying) return 0;; esac
  return 1
}

snippet_lookup(){ # $1 raw -> expansion or empty
  [ -f "$SNIPPETS" ] || return 0
  local key; key=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -d '[:punct:]' | sed 's/^ *//; s/ *$//')
  awk -F'=' -v k="$key" '
    /^[[:space:]]*#/ || NF<2 {next}
    { c=tolower($1); gsub(/^[ \t]+|[ \t]+$/,"",c); gsub(/[[:punct:]]/,"",c);
      if(c==k){ v=$0; sub(/^[^=]*=/,"",v); gsub(/^[ \t]+/,"",v); print v; exit } }' "$SNIPPETS"
}

cmd_stop(){
  [ -f "$PIDFILE" ] || { log "STOP: idle"; exit 0; }
  local rec mode; rec=$(cat "$PIDFILE"); rm -f "$PIDFILE"
  mode=$(cat "$MODEFILE" 2>/dev/null || echo dictate)
  kill -INT "$rec" 2>/dev/null
  for _ in $(seq 1 20); do kill -0 "$rec" 2>/dev/null || break; sleep 0.05; done
  blip stop
  [ -s "$WAV" ] || { notify "No audio"; exit 0; }
  [ "$(stat -c%s "$WAV")" -lt 12000 ] && { notify "Too short"; log "skip: short"; exit 0; }
  if [ "$STT_ENGINE" = parakeet ]; then
    [ -d "$ASR_MODEL_DIR" ] && [ -x "$ASR_PYTHON" ] || die "Parakeet not installed" "run: signet setup, or set STT_ENGINE=whisper"
  else
    [ -x "$WHISPER" ] || die "whisper not found" "run: signet doctor"
    [ -n "$MODEL" ] && [ -f "$MODEL" ] || die "no model" "run: signet setup"
  fi

  case "$mode" in
    command)   do_command ;;
    agent)     do_agent ;;
    *)         do_dictate ;;
  esac
}

do_dictate(){
  notify "✍️  Transcribing…"
  local raw; raw=$(transcribe "$LANG_CODE")
  raw=$(printf '%s' "$raw" | sed -E 's/([[:space:]]+(you|thank you|bye|so|uh|um)){2,}[[:punct:]]*[[:space:]]*$//I' | sed -E 's/[[:space:]]+$//')
  log "RAW: $raw"
  [ -z "$raw" ] && { notify "Nothing heard"; exit 0; }
  is_junk "$raw" && { notify "Nothing heard"; log "skip junk"; exit 0; }

  # snippet expansion (instant, pre-Gemma)
  local snip; snip=$(snippet_lookup "$raw")
  if [ -n "$snip" ]; then log "snippet: $raw -> $snip"; emit "$snip"; notify "✂️ Snippet" "$snip"; return; fi

  local clean=""
  if [ "$CLEANUP" != 1 ]; then clean="$raw"; log "fast mode"
  elif llm_ready "$DICTATE_BACKEND"; then
    local names sys; [ -f "$DICT" ] && names=$(grep -vE '^\s*$|^#' "$DICT" | paste -sd ', ')
    sys="Clean up dictated speech. Always: remove fillers (um, uh, like, you know) and false starts/repeated words; fix grammar; add correct capitalization and punctuation; write numbers, dates, times and money normally (e.g. 'three pm' -> '3 PM', 'twenty dollars' -> '\$20', 'june twenty' -> 'June 20'). If the speech enumerates three or more items, tasks, or steps — even when phrased as a sentence with 'and' — format them as a bullet list with '- ', keeping any lead-in phrase as a heading line. If a trailing remark (such as a time, date, or note) follows the items, put it on its own line after the list, not attached to the last item. Keep a single flowing thought (not an enumeration) as prose. Keep ALL the user's real words and meaning — never summarize, drop content, translate, or explain. Output ONLY the cleaned text.$(mode_hint)"
    [ -n "${names:-}" ] && sys="$sys If a word closely matches one of these names/terms phonetically, fix it to this exact spelling: $names."
    clean=$(llm_chat_messages "$DICTATE_BACKEND" "$(jq -n --arg s "$sys" --arg u "$raw" \
      '[{role:"system",content:$s},
        {role:"user",content:"um i has went to the store yesterday and buyed some stuff you know"},
        {role:"assistant",content:"I went to the store yesterday and bought some stuff."},
        {role:"user",content:"i need to buy milk eggs bread and coffee tomorrow"},
        {role:"assistant",content:"I need to buy:\n- milk\n- eggs\n- bread\n- coffee\n\ntomorrow"},
        {role:"user",content:"remember to call the bank pay rent and email john"},
        {role:"assistant",content:"Remember to:\n- call the bank\n- pay rent\n- email John"},
        {role:"user",content:"so i was thinking we could maybe meet tomorrow and discuss the project"},
        {role:"assistant",content:"I was thinking we could meet tomorrow and discuss the project."},
        {role:"user",content:"the meeting is at three pm on june twenty and it costs twenty dollars"},
        {role:"assistant",content:"The meeting is at 3 PM on June 20, and it costs $20."},
        {role:"user",content:$u}]')")
  else
    [ "$ON_OLLAMA_DOWN" = abort ] && die "Cleanup backend down" "ollama serve, or set GEMMA_BACKEND/AISTUDIO_KEY"
    notify "⚠️ Cleanup unavailable — raw text"; log "llm not ready"
  fi
  [ -z "$clean" ] && clean="$raw"
  log "CLEAN: $clean"
  emit "$clean"
  notify "✅ Done" "$clean"
}


do_command(){
  notify "🛠️  Reading command…"
  local instr; instr=$(transcribe "$LANG_CODE")
  log "INSTR: $instr"
  [ -z "$instr" ] && { notify "No command heard"; exit 0; }
  is_junk "$instr" && { notify "No command heard"; exit 0; }
  llm_ready "$AGENT_BACKEND" || die "Cleanup backend down" "command mode needs Gemma (ollama or AI Studio key)"

  # grab the currently selected text via clipboard (save + restore)
  wl-paste -n > "$CLIPBAK" 2>/dev/null || : > "$CLIPBAK"
  wtype -M ctrl c -m ctrl 2>>"$LOG"; sleep 0.25
  local seltext; seltext=$(wl-paste -n 2>/dev/null)
  if [ -z "$seltext" ]; then
    notify "Select text first" "command mode edits selected text"; log "command: no selection"
    [ -s "$CLIPBAK" ] && wl-copy < "$CLIPBAK"; return
  fi
  local out; out=$(gemma_chat "$AGENT_BACKEND" "Apply the user's instruction to their text. Output ONLY the resulting text, nothing else — no preamble, no quotes." "Instruction: $instr

Text:
$seltext")
  [ -z "$out" ] && { notify "Command failed"; [ -s "$CLIPBAK" ] && wl-copy < "$CLIPBAK"; return; }
  log "CMD OUT: $out"
  # paste over the selection
  printf '%s' "$out" | wl-copy; sleep 0.1
  wtype -M ctrl v -m ctrl 2>>"$LOG"
  ( sleep 1.5; [ -s "$CLIPBAK" ] && wl-copy < "$CLIPBAK" || wl-copy --clear 2>/dev/null ) &
  notify "🛠️ Done" "$out"
}

# ---------- agent mode (F10): voice -> one safe action ----------
do_agent(){
  notify "🤖 Listening…"
  local goal; goal=$(transcribe "$LANG_CODE")
  log "AGENT goal: $goal"
  [ -z "$goal" ] && { notify "Nothing heard"; exit 0; }
  is_junk "$goal" && { notify "Nothing heard"; exit 0; }
  llm_ready "$AGENT_BACKEND" || die "Agent backend down" "needs Gemma (set GEMMA_BACKEND/AISTUDIO_KEY)"

  local sys="You convert a spoken command into ONE action as strict JSON. Output ONLY a JSON object {\"action\":string,\"arg\":string} and nothing else. action MUST be exactly one of: open_app (launch an application; arg = app name), web_search (search the web; arg = the search query), find_file (find files on the computer; arg = filename or keywords), none (anything else; arg = \"\")."
  local raw_json; raw_json=$(llm_chat_messages "$AGENT_BACKEND" "$(jq -n --arg s "$sys" --arg u "$goal" '[
    {role:"system",content:$s},
    {role:"user",content:"open firefox"},               {role:"assistant",content:"{\"action\":\"open_app\",\"arg\":\"firefox\"}"},
    {role:"user",content:"can you launch spotify please"},{role:"assistant",content:"{\"action\":\"open_app\",\"arg\":\"spotify\"}"},
    {role:"user",content:"search google for the weather in kozhikode"},{role:"assistant",content:"{\"action\":\"web_search\",\"arg\":\"weather in kozhikode\"}"},
    {role:"user",content:"look up how to center a div"},  {role:"assistant",content:"{\"action\":\"web_search\",\"arg\":\"how to center a div\"}"},
    {role:"user",content:"find my resume pdf"},          {role:"assistant",content:"{\"action\":\"find_file\",\"arg\":\"resume pdf\"}"},
    {role:"user",content:"where are my vacation photos"}, {role:"assistant",content:"{\"action\":\"find_file\",\"arg\":\"vacation photos\"}"},
    {role:"user",content:"what is the capital of france"},{role:"assistant",content:"{\"action\":\"none\",\"arg\":\"\"}"},
    {role:"user",content:$u}]')")
  # extract the JSON object even if wrapped in prose/markdown
  local js; js=$(printf '%s' "$raw_json" | grep -oE '\{[^}]*\}' | head -1)
  local action arg
  action=$(printf '%s' "$js" | jq -r '.action // "none"' 2>/dev/null)
  arg=$(printf '%s' "$js" | jq -r '.arg // ""' 2>/dev/null)
  log "AGENT -> action=$action arg=$arg"
  case "$action" in
    open_app)   agent_open "$arg" ;;
    web_search) agent_search "$arg" ;;
    find_file)  agent_find "$arg" ;;
    *)          notify "🤷 Can't do that yet" "$goal" ;;
  esac
}
agent_open(){
  local a cmd=""; a=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed 's/^ *//; s/ *$//')
  [ -f "$CONFIG_DIR/apps" ] && cmd=$(awk -F= -v k="$a" 'tolower($1)~k && $2{gsub(/^[ \t]+|[ \t]+$/,"",$2); print $2; exit}' "$CONFIG_DIR/apps")
  if [ -z "$cmd" ]; then case "$a" in
    *browser*|*chrome*|*firefox*|*zen*) cmd=zen ;;
    *code*|*editor*|*vscode*) cmd=code ;;
    *term*|*kitty*|*console*) cmd=kitty ;;
    *file*|*folder*|*nautilus*|*files*) cmd=nautilus ;;
    *spotify*|*music*) cmd=spotify ;;
    *) cmd="$a" ;;
  esac; fi
  notify "🚀 Opening $cmd"; log "open_app: $cmd"
  if command -v app2unit >/dev/null 2>&1; then app2unit -- "$cmd" >/dev/null 2>&1 & 
  else hyprctl dispatch exec -- "$cmd" >/dev/null 2>&1; fi
}
agent_search(){
  [ -z "$1" ] && { notify "Nothing to search"; return; }
  local q; q=$(jq -rn --arg s "$1" '$s|@uri')
  notify "🔎 Searching" "$1"; log "web_search: $1"
  xdg-open "https://www.google.com/search?q=$q" >/dev/null 2>&1 &
}
agent_find(){
  [ -z "$1" ] && { notify "Nothing to find"; return; }
  notify "📁 Searching files…"
  local pat res; pat=$(printf '%s' "$1" | sed 's/  */.*/g')
  if command -v fd >/dev/null 2>&1; then
    res=$(fd -i -H -E .git -E node_modules -E .cache "$pat" "$HOME" 2>/dev/null | head -8)
  else
    res=$(find "$HOME" -iname "*$(printf '%s' "$1" | sed 's/  */*/g')*" -not -path '*/.*' 2>/dev/null | head -8)
  fi
  if [ -z "$res" ]; then notify "No files match" "$1"; log "find_file: 0 hits for $1"; return; fi
  printf '%s\n' "$res" | wl-copy 2>/dev/null
  log "find_file: $(printf '%s\n' "$res" | wc -l) hits for $1"
  notify "📁 Found (paths copied)" "$(printf '%s\n' "$res" | sed "s|$HOME/||" | head -6)"
}

emit(){
  case "$PASTE_MODE" in
    stdout)    printf '%s\n' "$1" ;;
    clipboard) printf '%s' "$1" | wl-copy; log "clipboard" ;;
    *)         paste_text "$1"; record_insert "$1" ;;
  esac
}
record_insert(){ # remember the last inserted text for undo + append to history
  printf '%s\n%s' "$(date +%s)" "$1" > "$LAST"
  printf '%s\t%s\n' "$(date '+%F %T')" "$1" >> "$HIST"
  # trim history to last 20 lines
  [ -f "$HIST" ] && tail -n 20 "$HIST" > "$HIST.tmp" 2>/dev/null && mv "$HIST.tmp" "$HIST"
}
paste_text(){
  local text="$1"
  have wtype || { printf '%s\n' "$text"; return; }
  local cls; cls=$(hyprctl activewindow -j 2>/dev/null | jq -r '.class // empty' | tr '[:upper:]' '[:lower:]')
  log "target class: $cls"
  case "$cls" in
    *zen*|*firefox*|*chrom*|*brave*|*navigator*|*mullvad*|*librewolf*|*vivaldi*|*edge*)
      if have wl-copy; then
        wl-paste -n > "$CLIPBAK" 2>/dev/null || : > "$CLIPBAK"
        printf '%s' "$text" | wl-copy; sleep 0.12
        wtype -M ctrl v -m ctrl 2>>"$LOG"; log "paste Ctrl+V (browser)"
        ( sleep 1.5; [ -s "$CLIPBAK" ] && wl-copy < "$CLIPBAK" || wl-copy --clear 2>/dev/null ) &
      else wtype -d "$WTYPE_DELAY" "$text" 2>>"$LOG"; fi ;;
    *)
      wtype -d "$WTYPE_DELAY" "$text" 2>>"$LOG"; log "typed direct (d=$WTYPE_DELAY)" ;;
  esac
}

cmd_toggle(){
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then exec "$0" stop; else exec "$0" start "${1:-dictate}"; fi
}
cmd_cancel(){ # kill an in-progress recording without transcribing
  [ -f "$PIDFILE" ] || return 1
  local rec; rec=$(cat "$PIDFILE"); rm -f "$PIDFILE" "$MODEFILE"
  kill -INT "$rec" 2>/dev/null; rm -f "$WAV"
  log "CANCELLED recording"; notify "✖ Cancelled"; return 0
}
cmd_undo(){ # Super+Backspace: cancel if recording, else undo last dictation (single-level, freshness-gated)
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then cmd_cancel; return; fi
  [ -f "$LAST" ] || exit 0
  local ts text now; ts=$(head -1 "$LAST"); text=$(tail -n +2 "$LAST"); now=$(date +%s)
  [ -z "$ts" ] && exit 0
  if [ $(( now - ts )) -gt "$UNDO_WINDOW" ]; then log "undo: too old, ignoring"; exit 0; fi
  local n=${#text}; [ "$n" -gt 0 ] || exit 0
  log "UNDO: removing $n chars"
  local args=(); local i=0; while [ "$i" -lt "$n" ]; do args+=(-k BackSpace); i=$((i+1)); done
  wtype "${args[@]}" 2>>"$LOG"
  rm -f "$LAST"; notify "↩ Undone" "${text:0:40}"
}
cmd_history(){ [ -f "$HIST" ] && tail -n "${1:-10}" "$HIST" || echo "(no history)"; }
cmd_warm(){
  [ "$STT_ENGINE" = parakeet ] && { asr_ensure && echo "parakeet warm" || echo "parakeet warm failed"; }
  if [ "$DICTATE_BACKEND" = local ] || [ "$AGENT_BACKEND" = local ]; then
    curl -s --max-time 90 "$OLLAMA/api/generate" -d "$(jq -n --arg m "$GEMMA" --arg k "$KEEP_ALIVE" '{model:$m,prompt:"hi",stream:false,think:false,keep_alive:$k}')" >/dev/null 2>&1 && echo "warmed $GEMMA (local)" || echo "gemma warm failed"
  else echo "cloud backend — no local warm needed"; fi
}

ok(){ printf '  \033[32m✓\033[0m %s\n' "$1"; }
bad(){ printf '  \033[31m✗\033[0m %s\n' "$1"; FAILED=1; }
cmd_doctor(){
  FAILED=0; echo "signet doctor (v$VERSION)"; echo "deps:"
  for c in pw-record ffmpeg jq curl wtype wl-copy wl-paste notify-send; do have "$c" && ok "$c" || bad "$c missing"; done
  have pw-play && ok "pw-play (sound)" || echo "  - pw-play missing (no sound cue)"
  echo "STT engine: $STT_ENGINE"
  if [ "$STT_ENGINE" = parakeet ]; then
    [ -x "$ASR_PYTHON" ] && ok "asr venv: $ASR_PYTHON" || bad "asr venv missing — run: signet setup"
    [ -d "$ASR_MODEL_DIR" ] && ok "parakeet model: $ASR_MODEL_DIR" || bad "parakeet model missing"
    [ -f "$ASR_SERVER" ] && ok "asr server script" || bad "signet-asr script missing"
    asr_up && ok "parakeet server running" || echo "  - parakeet server not running (starts on first use)"
  fi
  echo "whisper (fallback):"; [ -x "$WHISPER" ] && ok "$WHISPER" || echo "  - whisper-cli not found"
  [ -n "$MODEL" ] && [ -f "$MODEL" ] && ok "model: $MODEL" || echo "  - no whisper model"
  echo "brain: dictate=$DICTATE_BACKEND  agent=$AGENT_BACKEND"
  if [ "$DICTATE_BACKEND" = local ] || [ "$AGENT_BACKEND" = local ]; then
    echo "ollama (local backend):"
    if ollama_up; then ok "running"; curl -s "$OLLAMA/api/tags" | jq -e --arg g "$GEMMA" '.models[]?.name|select(.==$g)' >/dev/null 2>&1 && ok "$GEMMA pulled" || bad "$GEMMA not pulled — ollama pull $GEMMA"
    else bad "not running — ollama serve"; fi
  fi
  if [ "$DICTATE_BACKEND" = aistudio ] || [ "$AGENT_BACKEND" = aistudio ]; then
    echo "AI Studio (cloud backend):"
    [ -n "$AISTUDIO_KEY" ] && ok "key set (model $AISTUDIO_MODEL)" || bad "AISTUDIO_KEY missing in config"
  fi
  echo "mic:"; have wpctl && { case "$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ 2>/dev/null)" in *MUTED*) bad "mic MUTED — signet setup";; *) ok "$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ 2>/dev/null)";; esac; }
  echo "config: $CONFIG"
  [ "$FAILED" = 0 ] && echo "All good." || return 1
}
gen_cues(){ have ffmpeg || return 0
  [ -f "$DATA_DIR/start.wav" ] || ffmpeg -y -f lavfi -i "sine=frequency=880:duration=0.08" -af "afade=t=out:st=0.05:d=0.03" -ar 48000 "$DATA_DIR/start.wav" 2>/dev/null
  [ -f "$DATA_DIR/stop.wav" ]  || ffmpeg -y -f lavfi -i "sine=frequency=520:duration=0.08" -af "afade=t=out:st=0.05:d=0.03" -ar 48000 "$DATA_DIR/stop.wav" 2>/dev/null; }
cmd_setup(){
  echo "signet setup"
  [ -f "$CONFIG" ] || { write_default_config; echo "wrote $CONFIG"; }
  [ -f "$DICT" ] || { printf '# one name/term per line; signet fixes phonetic mishears to these spellings\n' > "$DICT"; echo "wrote $DICT"; }
  [ -f "$SNIPPETS" ] || { printf '# voice snippets:  cue = expansion\n# e.g.  my email = you@example.com\n' > "$SNIPPETS"; echo "wrote $SNIPPETS"; }
  gen_cues && echo "sound cues ready"
  have wpctl && { wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 0 2>/dev/null; wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 0.6 2>/dev/null; echo "mic unmuted @ 0.6"; }
  { [ -z "$MODEL" ] || [ ! -f "$MODEL" ]; } && { echo "downloading base.en…"; fetch_model && echo "model ready" || echo "model dl failed"; } || echo "model: $MODEL"
  ollama_up && { curl -s "$OLLAMA/api/tags" | jq -e --arg g "$GEMMA" '.models[]?.name|select(.==$g)' >/dev/null 2>&1 || { echo "pulling $GEMMA…"; ollama pull "$GEMMA"; }; } || echo "⚠️ ollama not running — then: ollama pull $GEMMA"
  local bin; bin=$(command -v signet || echo "$0")
  cat <<EOF

Add to ~/.config/hypr/hyprland.conf:
  exec-once = $bin warm                        # preload Parakeet + Gemma at login (no cold start)
  bind  = , F9,  exec, $bin start
  bindr = , F9,  exec, $bin stop
  bind  = , F10, exec, $bin start agent        # voice action: open app / web search / find files
  bindr = , F10, exec, $bin stop
  bind  = SUPER, BackSpace, exec, $bin undo     # cancel recording, or undo last dictation

Hold F9 dictate · F10 agent (open app / search / find files) · Super+Backspace cancel/undo.
Parakeet STT: if not installed, see README (uv venv + onnx-asr + model download).
EOF
}
fetch_model(){ curl -L --fail -o "$DATA_DIR/models/ggml-base.en.bin" "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin" && MODEL="$DATA_DIR/models/ggml-base.en.bin"; }
write_default_config(){ cat > "$CONFIG" <<EOF
# signet config
STT_ENGINE="parakeet"     # parakeet (fast, warm server, auto-language) | whisper (whisper.cpp)
ASR_MODEL_DIR="$DATA_DIR/models/parakeet-v3"
ASR_PORT=8126
GEMMA="gemma4:e2b"
KEEP_ALIVE="30m"          # keep Gemma warm (memory vs cold-reload speed); "-1" = never unload
# per-mode brain backend: local (e2b, offline/private) | aistudio (cloud Gemma 4, needs key)
DICTATE_BACKEND="local"   # F9 dictation
AGENT_BACKEND="aistudio"  # F10 agent (open app / search / find files)
# AISTUDIO_KEY="..."      # free key from aistudio.google.com/apikey (needed for cloud backends)
AISTUDIO_MODEL="gemma-4-26b-a4b-it"
LANG_CODE="en"
PASTE_MODE="auto"         # auto | paste | clipboard | stdout
CLEANUP=1                 # 1 = Gemma polish ; 0 = fast (whisper/parakeet only, ~half time)
MODE="auto"               # auto (pick from active window) | default | email | message | code | notes | formal
SOUND=1
WTYPE_DELAY=12            # ms between keys when typing directly
MIC="@DEFAULT_AUDIO_SOURCE@"
ON_OLLAMA_DOWN="warn-raw" # warn-raw | abort
THREADS=8
EOF
}
cmd_status(){
  echo "signet v$VERSION"; echo "whisper: $WHISPER"; echo "model:   ${MODEL:-<none>}"
  echo "gemma:   $GEMMA (keep_alive=$KEEP_ALIVE)  cleanup:$CLEANUP  mode:$MODE"
  echo "paste:   $PASTE_MODE  sound:$SOUND  typedelay:$WTYPE_DELAY  lang:$LANG_CODE"
  echo "recording:$([ -f "$PIDFILE" ] && echo ' active' || echo ' idle')"
  echo "--- log ---"; tail -n 8 "$LOG" 2>/dev/null
}
usage(){ cat <<EOF
signet v$VERSION — local voice dictation + AI commands (Hyprland)
usage: signet <command>
  start [dictate|command|agent]   begin recording (bind to key press)
  stop                                stop + process (bind to key release)
  toggle [mode]                       start/stop on one tap
  undo                                cancel recording, or undo the last dictation
  history [n]                         show recent dictations
  warm | setup | doctor | status | config | version
modes: dictate (clean+type) · agent (open app/search/find files)
EOF
}
case "${1:-}" in
  start) cmd_start "${2:-dictate}" ;;
  stop) cmd_stop ;;
  toggle) cmd_toggle "${2:-dictate}" ;;
  undo) cmd_undo ;;
  cancel) cmd_cancel ;;
  history) cmd_history "${2:-10}" ;;
  warm) cmd_warm ;;
  setup) cmd_setup ;;
  doctor) cmd_doctor ;;
  status) cmd_status ;;
  config) echo "$CONFIG" ;;
  version|--version|-v) echo "signet $VERSION" ;;
  ""|help|-h|--help) usage ;;
  *) echo "unknown: $1" >&2; usage; exit 1 ;;
esac

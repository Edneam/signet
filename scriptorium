#!/usr/bin/env bash
# scriptorium — local, private voice dictation for Hyprland.
# Speak, get clean text wherever your cursor is. whisper.cpp + Gemma, fully on-device.
set -uo pipefail

VERSION="0.1.0"
APP="scriptorium"

# ---------- XDG paths ----------
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/$APP"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/$APP"
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/$APP"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/$APP"
CONFIG="$CONFIG_DIR/config"
DICT="$CONFIG_DIR/dictionary.txt"
LOG="$STATE_DIR/scriptorium.log"
WAV="$RUNTIME_DIR/rec.wav"
CLEANWAV="$RUNTIME_DIR/rec_clean.wav"
PIDFILE="$RUNTIME_DIR/rec.pid"
CLIPBAK="$RUNTIME_DIR/clip.bak"
mkdir -p "$CONFIG_DIR" "$STATE_DIR" "$DATA_DIR/models" "$RUNTIME_DIR" 2>/dev/null

# ---------- defaults (override in $CONFIG) ----------
MODEL=""                       # auto-detected if empty
WHISPER=""                     # auto-detected if empty
GEMMA="gemma4:e2b"
OLLAMA="http://localhost:11434"
KEEP_ALIVE="30m"
LANG_CODE="en"
PASTE_MODE="auto"              # auto | paste | clipboard | stdout
SOUND=1                        # 1 = subtle start/stop cue
MIC="@DEFAULT_AUDIO_SOURCE@"
ON_OLLAMA_DOWN="warn-raw"      # warn-raw | abort
CLEANUP=1                      # 1 = Gemma polish (slower, nicer) ; 0 = fast mode (whisper only, ~half the time)
THREADS=8
[ -f "$CONFIG" ] && . "$CONFIG"

# auto-detect whisper binary: PATH (AUR) first, then a local source build
if [ -z "$WHISPER" ]; then
  WHISPER=$(command -v whisper-cli 2>/dev/null) || true
  [ -z "$WHISPER" ] && WHISPER="$HOME/projects/whisper.cpp/build/bin/whisper-cli"
fi
# auto-detect model: prefer base.en (fast) then small.en (more accurate, slower)
if [ -z "$MODEL" ]; then
  for m in "$DATA_DIR/models/ggml-base.en.bin" \
           "$HOME/projects/whisper.cpp/models/ggml-base.en.bin" \
           "$DATA_DIR/models/ggml-small.en.bin" \
           "$HOME/projects/whisper.cpp/models/ggml-small.en.bin"; do
    [ -f "$m" ] && { MODEL="$m"; break; }
  done
fi

# ---------- helpers ----------
log(){ echo "$(date '+%F %T') $*" >> "$LOG"; }
notify(){ command -v notify-send >/dev/null && notify-send -u low -t 2000 -a "Scriptorium" "$1" "${2:-}" 2>/dev/null || true; }
have(){ command -v "$1" >/dev/null 2>&1; }
blip(){ # $1 = start|stop ; subtle cue
  [ "$SOUND" = 1 ] || return 0
  local f="$DATA_DIR/$1.wav"
  [ -f "$f" ] && have pw-play && (pw-play --volume 0.4 "$f" >/dev/null 2>&1 &) || true
}
die(){ notify "⚠️ $1" "${2:-}"; log "ERROR: $1 ${2:-}"; echo "scriptorium: $1" >&2; exit 1; }

# rotate log if >1MB
[ -f "$LOG" ] && [ "$(stat -c%s "$LOG" 2>/dev/null || echo 0)" -gt 1048576 ] && mv "$LOG" "$LOG.1"

# ================= commands =================
cmd_start(){
  [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null && exit 0
  have pw-record || die "pw-record not found" "install pipewire"
  log "START recording (mic=$MIC)"
  notify "🎤 Recording…"
  blip start
  # warm the cleanup model WHILE you talk — hides Gemma's cold-load behind the recording
  ( curl -s --max-time 30 "$OLLAMA/api/generate" -d "$(jq -n --arg m "$GEMMA" --arg k "$KEEP_ALIVE" '{model:$m,prompt:"ok",stream:false,think:false,keep_alive:$k}')" >/dev/null 2>&1 & )
  pw-record --target "$MIC" --rate 16000 --channels 1 "$WAV" &
  echo $! > "$PIDFILE"
}

cmd_stop(){
  [ -f "$PIDFILE" ] || { log "STOP: no active recording"; exit 0; }
  local rec; rec=$(cat "$PIDFILE"); rm -f "$PIDFILE"
  kill -INT "$rec" 2>/dev/null
  for _ in $(seq 1 20); do kill -0 "$rec" 2>/dev/null || break; sleep 0.05; done
  blip stop

  [ -s "$WAV" ] || { notify "No audio captured"; log "STOP: empty wav"; exit 0; }
  local sz; sz=$(stat -c%s "$WAV"); log "STOP wav=$sz bytes"
  [ "$sz" -lt 12000 ] && { notify "Too short"; log "skip: too short"; exit 0; }

  [ -x "$WHISPER" ] || die "whisper not found ($WHISPER)" "run: scriptorium doctor"
  [ -n "$MODEL" ] && [ -f "$MODEL" ] || die "no whisper model" "run: scriptorium setup"

  # light filter: bandpass + trim leading/trailing silence + normalize (fast).
  # silence trimming (areverse trick) stops whisper hallucinating on pauses.
  local src="$WAV"
  if have ffmpeg; then
    ffmpeg -y -i "$WAV" -af "highpass=f=100,lowpass=f=8000,silenceremove=start_periods=1:start_duration=0.1:start_threshold=-45dB:detection=peak,areverse,silenceremove=start_periods=1:start_duration=0.1:start_threshold=-45dB:detection=peak,areverse,dynaudnorm=f=200" \
      -ar 16000 -ac 1 "$CLEANWAV" 2>/dev/null && [ -s "$CLEANWAV" ] && src="$CLEANWAV"
  fi

  local names=""
  [ -f "$DICT" ] && names=$(grep -vE '^\s*$|^#' "$DICT" | paste -sd ', ')

  notify "✍️  Transcribing…"
  local raw
  raw=$("$WHISPER" -m "$MODEL" -l "$LANG_CODE" -nt -sns -bo 1 -bs 1 ${names:+--prompt "$names"} \
        -f "$src" -t "$THREADS" 2>/dev/null | tr '\n' ' ' | sed 's/^ *//; s/ *$//')
  log "RAW: $raw"
  [ -z "$raw" ] && { notify "Nothing heard"; exit 0; }
  # strip trailing whisper hallucinations: 2+ repeated "you", or trailing filler bursts
  raw=$(printf '%s' "$raw" | sed -E 's/([[:space:]]+(you|thank you|bye|so|uh|um)){2,}[[:punct:]]*[[:space:]]*$//I' | sed -E 's/[[:space:]]+$//')
  # drop whisper silence/noise hallucinations (whole-output junk)
  local junk; junk=$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | tr -d '[:punct:][:space:]')
  case "$junk" in
    ""|you|youyou|thankyou|thanks|thanksforwatching|okay|ok|bye|so|uh|um|blankaudio|musicplaying) \
      notify "Nothing heard"; log "skip: junk '$raw'"; exit 0 ;;
  esac

  # ---- Gemma cleanup (graceful if ollama down; skipped in fast mode) ----
  local clean=""
  if [ "$CLEANUP" != 1 ]; then
    clean="$raw"; log "fast mode: skipped cleanup"
  elif curl -s --max-time 2 "$OLLAMA/api/tags" >/dev/null 2>&1; then
    local sys="You clean up dictated speech. Remove fillers (um, uh, like, you know) and false starts/repeated words. Keep the exact meaning, capitalization and punctuation. Never add, reword, translate, or explain. Output ONLY the cleaned text and nothing else."
    [ -n "$names" ] && sys="$sys Known names/terms — if a word closely matches one phonetically, correct it to this exact spelling: $names."
    clean=$(curl -s --max-time 60 "$OLLAMA/api/chat" -d "$(jq -n --arg t "$raw" --arg m "$GEMMA" --arg k "$KEEP_ALIVE" --arg sys "$sys" \
      '{model:$m,think:false,stream:false,keep_alive:$k,options:{temperature:0,num_predict:300,stop:["\nInput:","Input:"]},messages:[{role:"system",content:$sys},{role:"user",content:$t}]}')" \
      | jq -r '.message.content // empty' | sed 's/^ *//; s/ *$//')
  else
    if [ "$ON_OLLAMA_DOWN" = "abort" ]; then die "Ollama not running" "start it: systemctl --user start ollama (or ollama serve)"; fi
    notify "⚠️ Ollama down — raw text" "no cleanup applied"
    log "ollama down -> raw"
  fi
  [ -z "$clean" ] && clean="$raw"
  log "CLEAN: $clean"

  emit "$clean"
  notify "✅ Done" "$clean"
}

emit(){ # output the text per PASTE_MODE
  local text="$1"
  case "$PASTE_MODE" in
    stdout)    printf '%s\n' "$text" ;;
    clipboard) printf '%s' "$text" | wl-copy; log "copied to clipboard" ;;
    *)         paste_text "$text" ;;   # auto | paste
  esac
}

paste_text(){
  local text="$1"
  have wtype || { printf '%s\n' "$text"; return; }
  local cls; cls=$(hyprctl activewindow -j 2>/dev/null | jq -r '.class // empty' | tr '[:upper:]' '[:lower:]')
  log "target class: $cls"
  case "$cls" in
    *zen*|*firefox*|*chrom*|*brave*|*navigator*|*mullvad*|*librewolf*|*vivaldi*|*edge*)
      # browsers ignore synthetic typing in contenteditable -> clipboard + Ctrl+V.
      # save/restore clipboard, with a long delay so the paste finishes before restore (no race).
      if have wl-copy; then
        wl-paste -n > "$CLIPBAK" 2>/dev/null || : > "$CLIPBAK"
        printf '%s' "$text" | wl-copy
        sleep 0.12
        wtype -M ctrl v -m ctrl 2>>"$LOG"
        log "paste Ctrl+V (browser)"
        ( sleep 1.5; if [ -s "$CLIPBAK" ]; then wl-copy < "$CLIPBAK"; else wl-copy --clear 2>/dev/null; fi ) &
      else
        wtype -d 2 "$text" 2>>"$LOG"
      fi ;;
    *)
      # terminals (incl. opencode TUI) + native apps: type directly. No clipboard, no race.
      wtype -d 2 "$text" 2>>"$LOG"; log "typed direct" ;;
  esac
}

cmd_toggle(){
  if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then exec "$0" stop; else exec "$0" start; fi
}

cmd_warm(){
  curl -s --max-time 90 "$OLLAMA/api/generate" \
    -d "$(jq -n --arg m "$GEMMA" --arg k "$KEEP_ALIVE" '{model:$m,prompt:"hi",stream:false,think:false,keep_alive:$k}')" >/dev/null 2>&1 \
    && { echo "warmed $GEMMA"; log "warmed $GEMMA"; } || echo "warm failed (ollama down?)"
}

ok(){ printf '  \033[32m✓\033[0m %s\n' "$1"; }
bad(){ printf '  \033[31m✗\033[0m %s\n' "$1"; FAILED=1; }

cmd_doctor(){
  FAILED=0
  echo "scriptorium doctor (v$VERSION)"
  echo "deps:"
  for c in pw-record ffmpeg jq curl wtype wl-copy wl-paste notify-send; do
    have "$c" && ok "$c" || bad "$c missing"
  done
  have pw-play && ok "pw-play (sound cue)" || echo "  - pw-play missing (sound cue disabled)"
  echo "whisper:"
  [ -x "$WHISPER" ] && ok "binary: $WHISPER" || bad "whisper-cli not found ($WHISPER)"
  [ -n "$MODEL" ] && [ -f "$MODEL" ] && ok "model: $MODEL" || bad "no model — run: scriptorium setup"
  echo "ollama:"
  if curl -s --max-time 2 "$OLLAMA/api/tags" >/dev/null 2>&1; then
    ok "running at $OLLAMA"
    curl -s "$OLLAMA/api/tags" | jq -e --arg g "$GEMMA" '.models[]?.name | select(.==$g)' >/dev/null 2>&1 \
      && ok "model $GEMMA pulled" || bad "$GEMMA not pulled — run: ollama pull $GEMMA"
  else
    bad "not running — start: systemctl --user start ollama  (or: ollama serve)"
  fi
  echo "mic:"
  if have wpctl; then
    local m; m=$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ 2>/dev/null)
    case "$m" in *MUTED*) bad "default mic MUTED — run: scriptorium setup" ;; *) ok "mic: $m" ;; esac
  fi
  echo "config: $CONFIG"
  [ "$FAILED" = 0 ] && echo "All good." || { echo "Some checks failed (see above)."; return 1; }
}

gen_cues(){ # generate subtle start/stop blips
  have ffmpeg || return 0
  [ -f "$DATA_DIR/start.wav" ] || ffmpeg -y -f lavfi -i "sine=frequency=880:duration=0.08" -af "afade=t=out:st=0.05:d=0.03" -ar 48000 "$DATA_DIR/start.wav" 2>/dev/null
  [ -f "$DATA_DIR/stop.wav" ]  || ffmpeg -y -f lavfi -i "sine=frequency=520:duration=0.08" -af "afade=t=out:st=0.05:d=0.03" -ar 48000 "$DATA_DIR/stop.wav"  2>/dev/null
}

cmd_setup(){
  echo "scriptorium setup"
  # config
  [ -f "$CONFIG" ] || { write_default_config; echo "wrote $CONFIG"; }
  [ -f "$DICT" ] || { printf '# one name/term per line; scriptorium fixes phonetic mishears to these spellings\n' > "$DICT"; echo "wrote $DICT"; }
  # sound cues
  gen_cues && echo "generated sound cues"
  # mic
  if have wpctl; then wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 0 2>/dev/null; wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 0.6 2>/dev/null; echo "unmuted mic @ 0.6"; fi
  # model
  if [ -z "$MODEL" ] || [ ! -f "$MODEL" ]; then
    echo "downloading whisper small.en model…"
    fetch_model && echo "model ready" || echo "model download failed — see README"
  else echo "model present: $MODEL"; fi
  # ollama model
  if curl -s --max-time 2 "$OLLAMA/api/tags" >/dev/null 2>&1; then
    curl -s "$OLLAMA/api/tags" | jq -e --arg g "$GEMMA" '.models[]?.name|select(.==$g)' >/dev/null 2>&1 \
      || { echo "pulling $GEMMA…"; ollama pull "$GEMMA"; }
  else echo "⚠️ ollama not running — start it then: ollama pull $GEMMA"; fi
  echo
  echo "Add this to your Hyprland config (e.g. ~/.config/hypr/hyprland.conf):"
  echo "  bind  = , F9, exec, $(command -v scriptorium || echo "$0") start"
  echo "  bindr = , F9, exec, $(command -v scriptorium || echo "$0") stop"
  echo
  echo "Then: hold F9, speak, release. Run 'scriptorium doctor' to verify."
}

fetch_model(){
  local url="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin"
  local out="$DATA_DIR/models/ggml-base.en.bin"
  curl -L --fail -o "$out" "$url" && MODEL="$out"
}

write_default_config(){
  cat > "$CONFIG" <<EOF
# scriptorium config — uncomment/edit to override defaults
# MODEL="$DATA_DIR/models/ggml-base.en.bin"   # base.en=fast (default), small.en=more accurate/slower
# WHISPER="/usr/bin/whisper-cli"
GEMMA="gemma4:e2b"
KEEP_ALIVE="30m"          # keep Gemma warm between dictations (avoids slow cold reload)
LANG_CODE="en"
# PASTE_MODE: auto | paste | clipboard | stdout
PASTE_MODE="auto"
# CLEANUP: 1 = Gemma polish (nicer) ; 0 = fast mode (whisper only, ~half the time)
CLEANUP=1
SOUND=1
# MIC: @DEFAULT_AUDIO_SOURCE@ or a pw node id
MIC="@DEFAULT_AUDIO_SOURCE@"
# ON_OLLAMA_DOWN: warn-raw | abort
ON_OLLAMA_DOWN="warn-raw"
THREADS=8
EOF
}

cmd_status(){
  echo "scriptorium v$VERSION"
  echo "whisper:  $WHISPER"
  echo "model:    ${MODEL:-<none>}"
  echo "gemma:    $GEMMA  (keep_alive=$KEEP_ALIVE)"
  echo "paste:    $PASTE_MODE   sound:$SOUND   lang:$LANG_CODE"
  echo "recording:$([ -f "$PIDFILE" ] && echo ' active' || echo ' idle')"
  echo "--- last log ---"; tail -n 8 "$LOG" 2>/dev/null || echo "(no log yet)"
}

usage(){ cat <<EOF
scriptorium v$VERSION — local voice dictation for Hyprland
usage: scriptorium <command>
  start        begin recording (bind to key press)
  stop         stop, transcribe, clean, inject (bind to key release)
  toggle       start if idle, else stop (single-tap key)
  warm         preload the Gemma model
  setup        first-run: config, model, cues, mic, ollama, bind help
  doctor       check dependencies and config
  status       show config + recent activity
  config       print config path
  version      print version
EOF
}

case "${1:-}" in
  start) cmd_start ;;
  stop) cmd_stop ;;
  toggle) cmd_toggle ;;
  warm) cmd_warm ;;
  setup) cmd_setup ;;
  doctor) cmd_doctor ;;
  status) cmd_status ;;
  config) echo "$CONFIG" ;;
  version|--version|-v) echo "scriptorium $VERSION" ;;
  ""|help|-h|--help) usage ;;
  *) echo "unknown command: $1" >&2; usage; exit 1 ;;
esac
